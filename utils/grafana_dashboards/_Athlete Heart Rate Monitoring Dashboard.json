          },
          "format": "table",
          "rawSql": "SELECT \n  CASE \n    WHEN heart_rate < 40 THEN 'Very Low (<40)'\n    WHEN heart_rate BETWEEN 40 AND 59 THEN 'Low (40-59)'\n    WHEN heart_rate BETWEEN 60 AND 99 THEN 'Normal (60-99)'\n    WHEN heart_rate BETWEEN 100 AND 129 THEN 'Elevated (100-129)'\n    WHEN heart_rate BETWEEN 130 AND 149 THEN 'High (130-149)'\n    WHEN heart_rate >= 150 THEN 'Very High (150+)'\n  END as hr_zone,\n  COUNT(*) as count\nFROM athlete_heartrates\nWHERE athlete_id ~ '${athlete:regex}'\nAND timestamp > $__timeFrom() AND timestamp < $__timeTo()\nGROUP BY hr_zone\nORDER BY hr_zone;",
          "refId": "D",
          "timeColumn": "timestamp"
        }
      ],
      "title": "Heart Rate Zone Distribution",
      "type": "bargauge"
    },
