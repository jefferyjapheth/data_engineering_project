          "format": "table",
          "rawSql": "SELECT \n  athlete_id,\n  ROUND(AVG(heart_rate)::numeric, 1) as \"Average HR\",\n  MIN(heart_rate) as \"Minimum HR\",\n  MAX(heart_rate) as \"Maximum HR\",\n  COUNT(*) as \"Total Readings\",\n  COUNT(*) FILTER (WHERE heart_rate > 150) as \"High HR Events\",\n  COUNT(*) FILTER (WHERE heart_rate < 40) as \"Low HR Events\"\nFROM athlete_heartrates\nWHERE athlete_id ~ '${athlete:regex}'\nAND timestamp > $__timeFrom() AND timestamp < $__timeTo()\nGROUP BY athlete_id\nORDER BY athlete_id;",
          "refId": "C",
          "timeColumn": "timestamp"
        }
      ],
